{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ggsay",
  "version": "0.1.2",
  "identifier": "com.ggsay.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "GGSay",
        "width": 800,
        "height": 680,
        "minWidth": 760,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": [
          "English",
          "SimpChinese",
          "TradChinese",
          "Japanese",
          "Korean",
          "Spanish",
          "French",
          "German"
        ],
        "displayLanguageSelector": true
      }
    }
  }
}
